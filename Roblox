    coroutine.wrap(function()
        while true do
            wait(5)
            pcall(function()
                if settings.AutoStatPoints then
                    local args = {[1] = "DistributeStats"}
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
                end
            end)
        end
    end)()
    
    -- Print startup message
    print("Luquinhas Hub carregado com sucesso!")
