-- ========== FUN√З√ХES AUXILIARES ==========
local function getLocalPlayer()
    return player
end

local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function getHumanoid()
    local char = getCharacter()
    return char and char:FindFirstChild("Humanoid")
end

local function getHumanoidRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(position)
    local hrp = getHumanoidRootPart()
    if hrp then
        hrp.CFrame = position
    end
end

local function getClosestNPC()
    local closest = nil
    local shortestDist = math.huge
    local hrp = getHumanoidRootPart()
    
    if not hrp then return nil end
    
    for _, npc in pairs(workspace.NPCs:GetChildren()) do
        if npc:FindFirstChild("HumanoidRootPart") and npc.Humanoid.Health > 0 then
            local dist = (hrp.Position - npc.HumanoidRootPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closest = npc
            end
        end
    end
    return closest
end

local function combatCheck()
    if not toggles.AutoFarm then return end
    local npc = getClosestNPC()
    if npc then
        teleportTo(npc.HumanoidRootPart.CFrame)
    end
end

local function autoHeal()
    local humanoid = getHumanoid()
    if humanoid and humanoid.Health <= settings.HealAt then
        local args = {[1] = "Reset"}
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
    end
end

local function levelUpCheck()
    local args = {[1] = "LevelUp"}
    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
end

-- ========== SISTEMA DE FARM ==========
local function autoFarm()
    while toggles.AutoFarm and runService.RenderStepped:Wait() do
        pcall(function()
            autoHeal()
            levelUpCheck()
            
            local npc = getClosestNPC()
            if npc and npc.Humanoid.Health > 0 then
                local hrp = getHumanoidRootPart()
                if hrp then
                    hrp.CFrame = npc.HumanoidRootPart.CFrame * CFrame.new(0, 2, 4)
                end
            end
        end)
    end
end

local function autoFarmLevel()
    while toggles.AutoFarmLevel and runService.RenderStepped:Wait() do
        pcall(function()
            autoHeal()
            
            -- Get current level
            local level = player.Data.Level.Value
            if level >= settings.TargetLevel then
                toggles.AutoFarmLevel = false
                break
            end
            
            -- Find NPC for current level range
            local targetNPC = nil
            for _, npc in pairs(workspace.NPCs:GetChildren()) do
                if npc:FindFirstChild("HumanoidRootPart") and 
                   npc:FindFirstChild("Humanoid") and 
                   npc.Humanoid.Health > 0 then
                    -- Check if NPC is appropriate for level
                    local requiredLevel = npc:FindFirstChild("Level")
                    if requiredLevel and requiredLevel.Value <= level + 50 then
                        targetNPC = npc
                        break
                    end
                end
            end
            
            if targetNPC then
                local hrp = getHumanoidRootPart()
                if hrp then
                    hrp.CFrame = targetNPC.HumanoidRootPart.CFrame * CFrame.new(0, 2, 4)
                end
            end
        end)
    end
end

-- ========== AUTO COLLECT (Fruits/Materials) ==========
local function autoCollect()
    while toggles.AutoCollect and runService.RenderStepped:Wait() do
        pcall(function()
            -- Collect fruits
            for _, fruit in pairs(workspace:GetDescendants()) do
                if fruit:IsA("Model") and fruit:FindFirstChild("Handle") then
                    local hrp = getHumanoidRootPart()
                    if hrp and (hrp.Position - fruit.Handle.Position).Magnitude < 50 then
                        fruit.Handle.CFrame = hrp.CFrame
                    end
                end
            end
            
            -- Collect materials
            for _, material in pairs(workspace:GetDescendants()) do
                if material:IsA("Part") and material.Name:find("Material") then
                    local hrp = getHumanoidRootPart()
                    if hrp and (hrp.Position - material.Position).Magnitude < 30 then
                        firetouchinterest(hrp, material, 0)
                        firetouchinterest(hrp, material, 1)
                    end
                end
            end
        end)
    end
end

